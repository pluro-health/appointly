# Multi-stage build for Next.js web app
FROM node:22-alpine AS base

FROM base AS deps
RUN apk add --no-cache libc6-compat build-base python3 bash
WORKDIR /app

# Copy package files/workspaces
COPY package.json yarn.lock .yarnrc.yml ./
COPY .yarn ./.yarn
COPY apps ./apps
COPY packages ./packages

# Install dependencies
ENV NODE_OPTIONS="--max-old-space-size=16384"
ENV YARN_ENABLE_IMMUTABLE_INSTALLS=false
RUN yarn install --mode=skip-build

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Build the application
ENV NODE_OPTIONS="--max-old-space-size=16384"
RUN yarn workspace @calcom/web build

FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV BUILD_STANDALONE=true
ARG BUILD_DATE=unknown
ENV BUILD_DATE=${BUILD_DATE}

RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

# Copy the public folder
COPY --from=builder /app/apps/web/public ./apps/web/public

# Set the correct permission for prerender cache
RUN mkdir .next && chown nextjs:nodejs .next

# 👇 Copy standalone output so /app/server.js exists
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
# 👇 Keep static files at app path
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "server.js"]
